        <mxCell id="e7" value="預測結果" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;fontSize=14;fontFamily=Microsoft JhengHei;" edge="1" parent="1" source="training" target="application">
          <mxGeometry relative="1" as="geometry"/>
