<mxfile host="app.diagrams.net" modified="2026-05-15T12:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="chapter3-method-flow" name="第三章研究方法流程圖">
    <mxGraphModel dx="1400" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="第三章研究方法流程圖" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=34;fontStyle=1;fontFamily=Microsoft JhengHei;" vertex="1" parent="1">
          <mxGeometry x="410" y="25" width="580" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="農產品價格預測：資料處理、特徵建構、模型訓練與模型評估流程" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontFamily=Microsoft JhengHei;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="390" y="75" width="620" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="data_source" value="&lt;b&gt;資料來源&lt;/b&gt;&lt;br&gt;&lt;br&gt;農產品交易資料&lt;br&gt;價格、交易量、市場資訊&lt;br&gt;高麗菜、小白菜、花椰菜、青蔥、萵苣" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="260" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="weather_source" value="&lt;b&gt;輔助資料&lt;/b&gt;&lt;br&gt;&lt;br&gt;氣象資料&lt;br&gt;溫度、降雨、濕度、豪雨指標" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="260" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="preprocess" value="&lt;b&gt;資料前處理&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. 日期格式整理與排序&lt;br&gt;2. 缺漏值與異常值處理&lt;br&gt;3. 整合每日作物層級資料&lt;br&gt;4. 依時間切分訓練與測試資料&lt;br&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;避免未來資訊洩漏&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="180" width="300" height="235" as="geometry"/>
        </mxCell>
        <mxCell id="features" value="&lt;b&gt;特徵建構&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;價格特徵&lt;/b&gt;&lt;br&gt;落後期價格、移動平均、移動標準差&lt;br&gt;&lt;br&gt;&lt;b&gt;交易特徵&lt;/b&gt;&lt;br&gt;交易量、交易筆數、品項數、市場數&lt;br&gt;&lt;br&gt;&lt;b&gt;時間與氣象特徵&lt;/b&gt;&lt;br&gt;月份週期、溫度、降雨、濕度" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="140" width="330" height="315" as="geometry"/>
        </mxCell>
        <mxCell id="targets" value="&lt;b&gt;預測任務設計&lt;/b&gt;&lt;br&gt;&lt;br&gt;應變數：未來價格&lt;br&gt;target_h1：預測 1 日後價格&lt;br&gt;target_h5：預測 5 日後價格&lt;br&gt;target_h7 / target_h14：較長天期預測" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#9333ea;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="535" width="300" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="training" value="&lt;b&gt;模型訓練&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;機器學習回歸模型&lt;/b&gt;&lt;br&gt;Ridge、Random Forest&lt;br&gt;XGBoost、LightGBM&lt;br&gt;&lt;br&gt;&lt;b&gt;時間序列模型&lt;/b&gt;&lt;br&gt;SARIMA、Prophet&lt;br&gt;與 naive / moving average 基準模型比較" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2563eb;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="535" width="330" height="265" as="geometry"/>
        </mxCell>
        <mxCell id="evaluation" value="&lt;b&gt;模型評估&lt;/b&gt;&lt;br&gt;&lt;br&gt;MAE：平均絕對誤差&lt;br&gt;RMSE：均方根誤差&lt;br&gt;MAPE：百分比誤差&lt;br&gt;R²：解釋能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="610" width="260" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="application" value="&lt;b&gt;結果應用&lt;/b&gt;&lt;br&gt;&lt;br&gt;模型比較&lt;br&gt;短期價格趨勢&lt;br&gt;價格風險參考&lt;br&gt;輔助決策" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1190" y="535" width="150" height="265" as="geometry"/>
        </mxCell>
        <mxCell id="summary" value="研究重點：以歷史交易資料、時間特徵與氣象資料建立價格預測模型&lt;br&gt;比較不同模型於 1、5、7、14 日預測天期下之表現，作為短期價格趨勢與決策輔助參考" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;strokeWidth=2;fontSize=18;fontFamily=Microsoft JhengHei;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="225" y="865" width="950" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="e1" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;" edge="1" parent="1" source="data_source" target="preprocess">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;" edge="1" parent="1" source="weather_source" target="preprocess">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="整理後資料" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;fontSize=14;fontFamily=Microsoft JhengHei;" edge="1" parent="1" source="preprocess" target="features">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="建立 X" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;fontSize=14;fontFamily=Microsoft JhengHei;" edge="1" parent="1" source="features" target="training">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="建立 y" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;fontSize=14;fontFamily=Microsoft JhengHei;" edge="1" parent="1" source="targets" target="training">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="" style="endArrow=block;html=1;rounded=0;strokeWidth=3;strokeColor=#475569;" edge="1" parent="1" source="training" target="evaluation">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="650" y="805"/>
              <mxPoint x="340" y="735"/>
            </Array>
          </mxGeometry>
