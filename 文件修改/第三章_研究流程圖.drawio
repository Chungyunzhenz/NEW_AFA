        <mxCell id="e8" value="" style="endArrow=block;html=1;rounded=0;dashed=1;dashPattern=8 8;strokeWidth=2;strokeColor=#94a3b8;" edge="1" parent="1" source="evaluation" target="summary">
          <mxGeometry relative="1" as="geometry"/>
